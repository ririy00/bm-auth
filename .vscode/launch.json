  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Auth Service: Debug",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:debug", "--workspace", "@bm/auth-service"],
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "API Gateway: Debug",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:debug", "--workspace", "@bm/api-gateway"],
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "cwd": "${workspaceFolder}"
    }
  ]
}
