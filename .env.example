# Root environment for local infrastructure (docker-compose, ports).

# Auth DB container
AUTH_POSTGRES_USER="auth_user"
AUTH_POSTGRES_PASSWORD="auth_password"
AUTH_POSTGRES_DB="bm_auth"
AUTH_POSTGRES_PORT="5433:5432"

# Payment DB container
PAYMENT_POSTGRES_USER="payment_user"
PAYMENT_POSTGRES_PASSWORD="payment_password"
PAYMENT_POSTGRES_DB="bm_payment"
PAYMENT_POSTGRES_PORT="5434:5432"

# PG Admin
PGADMIN_DEFAULT_EMAIL="admin@example.com"
PGADMIN_DEFAULT_PASSWORD="admin"
PGADMIN_PORT="5050:80"
