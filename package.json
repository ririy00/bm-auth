{
  "name": "bm-monorepo",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "npm@11.5.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:auth": "npm run dev --workspace @bm/auth-service",
    "dev:gateway": "npm run dev --workspace @bm/api-gateway",
    "start:auth": "npm run start --workspace @bm/auth-service",
    "start:gateway": "npm run start --workspace @bm/api-gateway",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "prisma:generate": "turbo run prisma:generate --filter=@bm/auth-database --filter=@bm/payment-database",
    "prisma:generate:auth": "npm run prisma:generate --workspace @bm/auth-database",
    "prisma:generate:payment": "npm run prisma:generate --workspace @bm/payment-database",
    "prisma:migrate:auth": "npm run prisma:migrate --workspace @bm/auth-database",
    "prisma:migrate:payment": "npm run prisma:migrate --workspace @bm/payment-database",
    "prisma:studio:auth": "npm run prisma:studio --workspace @bm/auth-database",
    "prisma:studio:payment": "npm run prisma:studio --workspace @bm/payment-database"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.19.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  }
}
