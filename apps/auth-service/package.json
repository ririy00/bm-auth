{
  "name": "@bm/auth-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "db:generate": "npm --prefix ../.. run prisma:generate:auth",
    "prebuild": "npm run db:generate",
    "build": "nest build",
    "prestart": "npm run db:generate",
    "start": "nest start",
    "predev": "npm run db:generate",
    "dev": "nest start --watch",
    "prestart:dev": "npm run db:generate",
    "start:dev": "nest start --watch",
    "prestart:debug": "npm run db:generate",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "pretest": "npm run db:generate",
    "test": "jest",
    "pretest:watch": "npm run db:generate",
    "test:watch": "jest --watch",
    "pretest:cov": "npm run db:generate",
    "test:cov": "jest --coverage",
    "pretest:debug": "npm run db:generate",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register ../../node_modules/jest/bin/jest.js --runInBand",
    "pretest:e2e": "npm run db:generate",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@bm/auth-database": "*",
    "@nestjs/common": "^11.1.13",
    "@nestjs/core": "^11.1.13",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.13",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^16.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  },
  "prisma": {
    "schema": "../../packages/auth-database/prisma/schema.prisma"
  }
}
